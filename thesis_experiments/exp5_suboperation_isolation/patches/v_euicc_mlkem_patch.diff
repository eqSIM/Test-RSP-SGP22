+/** BER/DER length after tag (short or long form). Returns 0 on success. */
+static int read_ber_len(const uint8_t *p, uint32_t rem, uint32_t *out_len, uint32_t *consumed) {
+    if (rem < 1) {
+        return -1;
+    }
+    if (p[0] < 0x80) {
+        *out_len = p[0];
+        *consumed = 1;
+        return 0;
+    }
+    uint8_t n = (uint8_t)(p[0] & 0x7f);
+    if (n == 0 || n > 4 || rem < 1 + n) {
+        return -1;
+    }
+    uint32_t v = 0;
+    for (uint8_t i = 0; i < n; i++) {
+        v = (v << 8) | p[1 + i];
+    }
+    *out_len = v;
+    *consumed = 1 + n;
+    return 0;
+}
