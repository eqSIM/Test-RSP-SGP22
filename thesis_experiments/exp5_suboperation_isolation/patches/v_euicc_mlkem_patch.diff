diff --git a/v-euicc/src/crypto.c b/v-euicc/src/crypto.c
index 81df8c3..a95bbb7 100644
--- a/v-euicc/src/crypto.c
+++ b/v-euicc/src/crypto.c
@@ -377,3 +377,29 @@ int derive_session_keys_ecka(const uint8_t *euicc_otsk, uint32_t euicc_otsk_len,
     return 0;
 }
 
+int derive_session_keys_from_shared_secret(const uint8_t *shared_secret, uint32_t secret_len,
+                                           uint8_t *session_key_enc, uint8_t *session_key_mac) {
+    if (!shared_secret || secret_len != 32 || !session_key_enc || !session_key_mac) {
+        fprintf(stderr, "[crypto] derive_session_keys_from_shared_secret: invalid args\n");
+        return -1;
+    }
+    uint8_t kdf_input[36];
+    memcpy(kdf_input, shared_secret, 32);
+    kdf_input[32] = 0x00;
+    kdf_input[33] = 0x00;
+    kdf_input[34] = 0x00;
+    kdf_input[35] = 0x01;
+    uint8_t kek_hash[32];
+    SHA256(kdf_input, 36, kek_hash);
+    memcpy(session_key_enc, kek_hash, 16);
+    kdf_input[35] = 0x02;
+    uint8_t km_hash[32];
+    SHA256(kdf_input, 36, km_hash);
+    memcpy(session_key_mac, km_hash, 16);
+    memset(kdf_input, 0, sizeof(kdf_input));
+    memset(kek_hash, 0, sizeof(kek_hash));
+    memset(km_hash, 0, sizeof(km_hash));
+    fprintf(stderr, "[crypto] Session keys derived from shared secret (KEK + KM)\n");
+    return 0;
+}
+
